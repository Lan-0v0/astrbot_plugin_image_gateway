{
  "enable_nl_trigger": {
    "description": "启用自然语言触发",
    "hint": "开启后 LLM 可通过函数工具触发生图/改图；指令始终拥有最高优先级",
    "type": "bool",
    "default": true,
    "obvious_hint": true
  },
  "global_retry_count": {
    "description": "全局默认重试次数",
    "hint": "单个模型未单独配置（-1）时使用此值",
    "type": "int",
    "default": 2,
    "obvious_hint": true
  },
  "global_max_generation_count": {
    "description": "全局默认最大生成张数上限",
    "hint": "-1 表示不限制；单模型可单独覆盖，超出后提示「超出生成张数上限」",
    "type": "int",
    "default": 2,
    "obvious_hint": true
  },
  "models": {
    "description": "图像生成模型列表",
    "hint": "按优先级从高到低尝试；仅启用的模型参与生成",
    "type": "template_list",
    "templates": {
      "openai": {
        "name": "OpenAI",
        "hint": "OpenAI Images API 或兼容网关",
        "display_item": "display_name",
        "items": {
          "display_name": {
            "description": "显示名称",
            "type": "string",
            "default": "OpenAI 模型"
          },
          "enabled": {
            "description": "启用",
            "type": "bool",
            "default": true
          },
          "priority": {
            "description": "优先级",
            "hint": "数值越大越优先",
            "type": "int",
            "default": 10
          },
          "url": {
            "description": "API 地址",
            "hint": "例如 https://api.openai.com/v1",
            "type": "string",
            "default": "https://api.openai.com/v1"
          },
          "apikey": {
            "description": "API Key",
            "type": "string",
            "default": ""
          },
          "model_name": {
            "description": "模型名称",
            "hint": "例如 gpt-image-2",
            "type": "string",
            "default": "gpt-image-2"
          },
          "retry_count": {
            "description": "重试次数",
            "hint": "-1 表示使用全局默认",
            "type": "int",
            "default": -1
          },
          "max_generation_count": {
            "description": "最大生成张数",
            "hint": "-1 表示使用全局默认",
            "type": "int",
            "default": -1
          },
          "quality": {
            "description": "画质",
            "type": "string",
            "default": "high",
            "options": [
              "auto",
              "high",
              "medium",
              "low"
            ]
          },
          "size": {
            "description": "尺寸",
            "type": "string",
            "default": "1024x1024",
            "options": [
              "auto",
              "1024x1024",
              "1536x1024",
              "1024x1536",
              "256x256",
              "512x512"
            ]
          },
          "moderation": {
            "description": "内容审核/安全等级",
            "hint": "none 将尝试多种方式降低过滤强度",
            "type": "string",
            "default": "auto",
            "options": [
              "none",
              "low",
              "high",
              "auto"
            ],
            "labels": [
              "关闭 (none)",
              "低 (low)",
              "中高 (high)",
              "自动 (auto)"
            ]
          },
          "seed": {
            "description": "随机种子",
            "hint": "留空表示随机；部分模型/网关不支持",
            "type": "string",
            "default": ""
          }
        }
      },
      "gemini": {
        "name": "Gemini",
        "hint": "Google Gemini 图像生成或 Imagen 兼容接口",
        "display_item": "display_name",
        "items": {
          "display_name": {
            "description": "显示名称",
            "type": "string",
            "default": "Gemini 模型"
          },
          "enabled": {
            "description": "启用",
            "type": "bool",
            "default": true
          },
          "priority": {
            "description": "优先级",
            "hint": "数值越大越优先",
            "type": "int",
            "default": 10
          },
          "url": {
            "description": "API 地址",
            "hint": "例如 https://generativelanguage.googleapis.com/v1beta",
            "type": "string",
            "default": "https://generativelanguage.googleapis.com/v1beta"
          },
          "apikey": {
            "description": "API Key",
            "type": "string",
            "default": ""
          },
          "model_name": {
            "description": "模型名称",
            "hint": "例如 gemini-2.0-flash-preview-image-generation",
            "type": "string",
            "default": "gemini-2.0-flash-preview-image-generation"
          },
          "retry_count": {
            "description": "重试次数",
            "hint": "-1 表示使用全局默认",
            "type": "int",
            "default": -1
          },
          "max_generation_count": {
            "description": "最大生成张数",
            "hint": "-1 表示使用全局默认",
            "type": "int",
            "default": -1
          },
          "quality": {
            "description": "画质/输出质量",
            "hint": "部分网关支持 quality 参数",
            "type": "string",
            "default": "high",
            "options": [
              "auto",
              "high",
              "medium",
              "low"
            ]
          },
          "size": {
            "description": "尺寸/宽高比",
            "hint": "Gemini 原生接口可能忽略此字段",
            "type": "string",
            "default": "1024x1024",
            "options": [
              "auto",
              "1024x1024",
              "1536x1024",
              "1024x1536",
              "1:1",
              "16:9",
              "9:16"
            ]
          },
          "moderation": {
            "description": "安全过滤等级",
            "hint": "none 将尝试 BLOCK_NONE 等多种方式，失败后回退到最低等级",
            "type": "string",
            "default": "default",
            "options": [
              "none",
              "low",
              "high",
              "default"
            ],
            "labels": [
              "关闭 (none)",
              "低 (low)",
              "中高 (high)",
              "默认 (default)"
            ]
          },
          "seed": {
            "description": "随机种子",
            "hint": "留空表示随机",
            "type": "string",
            "default": ""
          }
        }
      }
    }
  },
  "generation_start_message": {
    "description": "生图开始提示",
    "hint": "控制开始生成前发送的提示语；支持固定语句随机发送或 LLM 生成",
    "type": "object",
    "items": {
      "mode": {
        "description": "提示语模式",
        "type": "string",
        "default": "fixed",
        "options": [
          "fixed",
          "llm"
        ],
        "labels": [
          "固定语句",
          "LLM"
        ]
      },
      "fixed_messages": {
        "description": "固定语句列表",
        "hint": "固定语句模式下随机发送，默认为「开始生成」",
        "type": "list",
        "default": [
          "开始生成"
        ],
        "condition": {
          "mode": "fixed"
        }
      },
      "llm_provider_id": {
        "description": "LLM 提示语提供商",
        "hint": "留空则跟随当前默认提供商",
        "type": "string",
        "default": "",
        "_special": "select_provider",
        "condition": {
          "mode": "llm"
        }
      },
      "llm_persona_source": {
        "description": "LLM 提示语人设来源",
        "type": "string",
        "default": "current",
        "options": [
          "current",
          "custom"
        ],
        "labels": [
          "使用当前人设",
          "自定义人设提示词"
        ],
        "condition": {
          "mode": "llm"
        }
      },
      "llm_custom_persona_prompt": {
        "description": "自定义人设提示词",
        "type": "text",
        "default": "根据现在的情景，以适宜的性格言语，简单表述要开始生成图片了，不分段不加格式不使用emoji，10字以内。",
        "hint": "仅在选择自定义人设提示词时生效",
        "condition": {
          "mode": "llm",
          "llm_persona_source": "custom"
        }
      }
    }
  }
}
