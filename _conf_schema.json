  "workflow_node_bindings": {
    "description": "工作流自定义节点条目",
    "hint": "它是用来告诉插件：工作流里的哪个节点、哪个字段，应该被什么内容自动替换。ComfyUI 采用节点ID+字段路径；A1111 请将节点ID填 _root，字段路径填 prompt、negative_prompt、seed、denoise 等顶层字段",
    "type": "template_list",
    "templates": {
      "binding": {
        "name": "自定义节点条目",
        "display_item": [
          "display_summary"
        ],
        "hide_hint_in_list": true,
        "items": {
          "display_summary": {
            "description": "Display Summary",
            "type": "string",
            "default": "",
            "invisible": true
          },
          "display_name": {
            "description": "显示名称",
            "hint": "给这条规则起一个你自己容易识别的名字，例如“正向提示词节点”“反向提示词节点”“CFG 参数节点”",
            "type": "string",
            "default": "节点覆盖规则"
          },
          "workflow_id": {
            "description": "所属工作流 ID",
            "hint": "必须与上方某个工作流条目的“工作流 ID”完全一致",
            "type": "string",
            "default": "comfyui_workflow"
          },
          "node_id": {
            "description": "节点 ID",
            "hint": "就是工作流 JSON 里最外层那串节点编号。例如最外层如果有一个编号 6 的节点，那这里就填 6。你只需要照着导出的 API JSON 里最外层的编号填写即可",
            "type": "string",
            "default": ""
          },
          "field_path": {
            "description": "字段路径",
            "hint": "用点号一步一步定位到你想修改的那一项。最常见的是 inputs.text，表示“这个节点里的 inputs 下面的 text”。如果某一项是列表里的第 1 个元素，就像 inputs.texts.0 这样写，最后的 0 表示第一个位置",
            "type": "string",
            "default": "inputs.text"
          },
          "binding_type": {
            "description": "内容类型",
            "hint": "正向提示词应通过 /生图 /改图 指令输入；图片输入为 /改图 指令专用，这两种类型都不需要在配置面板里额外填写输入框。模式切换类型只在“文生图 + 改图”这类双模式工作流里才会用到：文本=两种模式填不同文字，数值=两种模式填不同数字，JSON=两种模式填不同 JSON 值（常用于切换节点引用）。第一次接触时，最常见的是用“模式切换数值”切 denoise，用“模式切换 JSON”切 latent_image",
            "type": "string",
            "default": "prompt_positive",
            "options": [
              "prompt_positive",
              "prompt_negative",
              "image_input",
              "seed",
              "custom_text",
              "custom_number",
              "mode_switch_text",
              "mode_switch_number",
              "mode_switch_json"
            ],
            "labels": [
              "正向提示词",
              "反向提示词",
              "图片输入",
              "随机种子",
              "自定义文本",
              "自定义数值",
