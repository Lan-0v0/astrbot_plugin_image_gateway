{
  "enable_nl_trigger": {
    "description": "启用自然语言触发",
    "hint": "开启后 LLM 可通过函数工具触发生图/改图；指令始终拥有最高优先级",
    "type": "bool",
    "default": true,
    "obvious_hint": true
  },
  "global_retry_count": {
    "description": "全局默认重试次数",
    "hint": "单个模型未单独配置（-1）时使用此值",
    "type": "int",
    "default": 2,
    "obvious_hint": true
  },
  "global_max_generation_count": {
    "description": "全局默认单次请求最大生成张数上限",
    "hint": "-1 表示不限制；单模型可单独覆盖，超出后提示「超出生成张数上限」",
    "type": "int",
    "default": 2,
    "obvious_hint": true
  },
  "models": {
    "description": "图像生成模型列表",
    "hint": "按优先级从高到低尝试；仅启用的模型参与生成",
    "type": "template_list",
    "templates": {
      "openai": {
        "name": "OpenAI",
        "hint": "OpenAI Images API 或兼容网关",
        "display_item": "display_name",
        "items": {
          "display_name": {
            "description": "显示名称",
            "type": "string",
            "default": "OpenAI 模型"
          },
          "enabled": {
            "description": "启用",
            "type": "bool",
            "default": true
          },
          "priority": {
            "description": "优先级",
            "hint": "数值越大越优先",
            "type": "int",
            "default": 10
          },
          "url": {
            "description": "API 地址",
            "hint": "例如 https://api.openai.com/v1",
            "type": "string",
            "default": "https://api.openai.com/v1"
          },
          "apikey": {
            "description": "API Key",
            "type": "string",
            "default": ""
          },
          "model_name": {
            "description": "模型名称",
            "hint": "例如 gpt-image-2",
            "type": "string",
            "default": "gpt-image-2"
          },
          "retry_count": {
            "description": "重试次数",
            "hint": "-1 表示使用全局默认",
            "type": "int",
            "default": -1
          },
          "max_generation_count": {
            "description": "单次请求最大生成张数",
            "hint": "-1 表示使用全局默认",
            "type": "int",
            "default": -1
          },
          "quality": {
            "description": "画质",
            "type": "string",
            "default": "high",
            "options": [
              "auto",
              "high",
              "medium",
              "low"
            ]
          },
          "size": {
            "description": "尺寸",
            "type": "string",
            "default": "1024x1024",
            "options": [
              "auto",
              "1024x1024",
              "1536x1024",
              "1024x1536",
              "256x256",
              "512x512"
            ]
          },
          "moderation": {
            "description": "内容审核/安全等级",
            "hint": "none 将尝试多种方式降低过滤强度",
            "type": "string",
            "default": "auto",
            "options": [
              "none",
              "low",
              "high",
              "auto"
            ],
            "labels": [
              "关闭 (none)",
              "低 (low)",
              "中高 (high)",
              "自动 (auto)"
            ]
          },
          "seed": {
            "description": "随机种子",
            "hint": "留空表示随机；部分模型/网关不支持",
            "type": "string",
            "default": ""
          },
          "send_strategy": {
            "description": "发送链路",
            "hint": "跟随全局表示使用最底部的「全局发送链路」配置；也可为该模型单独指定",
            "type": "string",
            "default": "follow_global",
            "options": [
              "follow_global",
              "direct_first",
              "event_send_first",
              "context_send_first",
              "platform_client_first",
              "result_pipeline_only"
            ],
            "labels": [
              "跟随全局",
              "直连优先（默认）",
              "事件发送优先",
              "上下文发送优先",
              "平台客户端优先",
              "仅结果管道"
            ]
          }
        }
      },
      "gemini": {
        "name": "Gemini",
        "hint": "Google Gemini 图像生成或 Imagen 兼容接口",
        "display_item": "display_name",
        "items": {
          "display_name": {
            "description": "显示名称",
            "type": "string",
            "default": "Gemini 模型"
          },
          "enabled": {
            "description": "启用",
            "type": "bool",
            "default": true
          },
          "priority": {
            "description": "优先级",
            "hint": "数值越大越优先",
            "type": "int",
            "default": 10
          },
          "url": {
            "description": "API 地址",
            "hint": "例如 https://generativelanguage.googleapis.com/v1beta",
            "type": "string",
            "default": "https://generativelanguage.googleapis.com/v1beta"
          },
          "apikey": {
            "description": "API Key",
            "type": "string",
            "default": ""
          },
          "model_name": {
            "description": "模型名称",
            "hint": "例如 gemini-2.0-flash-preview-image-generation",
            "type": "string",
            "default": "gemini-2.0-flash-preview-image-generation"
          },
          "retry_count": {
            "description": "重试次数",
            "hint": "-1 表示使用全局默认",
            "type": "int",
            "default": -1
          },
          "max_generation_count": {
            "description": "单次请求最大生成张数",
            "hint": "-1 表示使用全局默认",
            "type": "int",
            "default": -1
          },
          "quality": {
            "description": "画质/输出质量",
            "hint": "部分网关支持 quality 参数",
            "type": "string",
            "default": "high",
            "options": [
              "auto",
              "high",
              "medium",
              "low"
            ]
          },
          "size": {
            "description": "尺寸/宽高比",
            "hint": "Gemini 原生接口可能忽略此字段",
            "type": "string",
            "default": "1024x1024",
            "options": [
              "auto",
              "1024x1024",
              "1536x1024",
              "1024x1536",
              "1:1",
              "16:9",
              "9:16"
            ]
          },
          "moderation": {
            "description": "安全过滤等级",
            "hint": "none 将尝试 BLOCK_NONE 等多种方式，失败后回退到最低等级",
            "type": "string",
            "default": "default",
            "options": [
              "none",
              "low",
              "high",
              "default"
            ],
            "labels": [
              "关闭 (none)",
              "低 (low)",
              "中高 (high)",
              "默认 (default)"
            ]
          },
          "seed": {
            "description": "随机种子",
            "hint": "留空表示随机",
            "type": "string",
            "default": ""
          },
          "send_strategy": {
            "description": "发送链路",
            "hint": "跟随全局表示使用最底部的「全局发送链路」配置；也可为该模型单独指定",
            "type": "string",
            "default": "follow_global",
            "options": [
              "follow_global",
              "direct_first",
              "event_send_first",
              "context_send_first",
              "platform_client_first",
              "result_pipeline_only"
            ],
            "labels": [
              "跟随全局",
              "直连优先（默认）",
              "事件发送优先",
              "上下文发送优先",
              "平台客户端优先",
              "仅结果管道"
            ]
          }
        }
      }
    }
  },
  "workflows": {
    "description": "工作流（Workflow）列表",
    "hint": "第一版仅支持 ComfyUI 文生图工作流；与图像生成模型列表统一参与调度，按优先级从高到低尝试",
    "type": "template_list",
    "templates": {
      "comfyui": {
        "name": "ComfyUI",
        "hint": "需要粘贴 ComfyUI 使用“导出（API 格式）”得到的完整工作流 JSON",
        "display_item": "display_name",
        "items": {
          "workflow_id": {
            "description": "工作流 ID",
            "hint": "用于关联下方“工作流自定义节点条目”。建议使用稳定、唯一的英文或拼音标识，例如 portrait_flux",
            "type": "string",
            "default": "comfyui_workflow"
          },
          "display_name": {
            "description": "显示名称",
            "type": "string",
            "default": "ComfyUI 工作流"
          },
          "enabled": {
            "description": "启用",
            "type": "bool",
            "default": true
          },
          "priority": {
            "description": "优先级",
            "hint": "数值越大越优先；与图像生成模型列表共用同一套优先级顺序",
            "type": "int",
            "default": 10
          },
          "retry_count": {
            "description": "重试次数",
            "hint": "-1 表示使用全局默认",
            "type": "int",
            "default": -1
          },
          "max_generation_count": {
            "description": "单次请求最大生成张数",
            "hint": "-1 表示使用全局默认",
            "type": "int",
            "default": -1
          },
          "workflow_type": {
            "description": "工作流类型",
            "hint": "当前仅支持 ComfyUI",
            "type": "string",
            "default": "comfyui",
            "options": [
              "comfyui"
            ]
          },
          "runtime_base_url_override": {
            "description": "ComfyUI 地址覆盖",
            "hint": "留空则使用下方「ComfyUI 运行环境（全局默认）」配置",
            "type": "string",
            "default": ""
          },
          "runtime_api_key_override": {
            "description": "ComfyUI 鉴权 Token 覆盖",
            "hint": "留空则使用全局配置；部分 ComfyUI 部署无需鉴权",
            "type": "string",
            "default": ""
          },
          "workflow_content": {
            "description": "工作流内容（API 格式 JSON）",
            "hint": "必须是从 ComfyUI 点击“导出（API 格式）”得到的完整 JSON，不要使用普通导出格式",
            "type": "text",
            "default": ""
          },
          "send_strategy": {
            "description": "发送链路",
            "hint": "跟随全局表示使用最底部的「全局发送链路」配置；也可为该工作流单独指定",
            "type": "string",
            "default": "follow_global",
            "options": [
              "follow_global",
              "direct_first",
              "event_send_first",
              "context_send_first",
              "platform_client_first",
              "result_pipeline_only"
            ],
            "labels": [
              "跟随全局",
              "直连优先（默认）",
              "事件发送优先",
              "上下文发送优先",
              "平台客户端优先",
              "仅结果管道"
            ]
          }
        }
      }
    }
  },
  "workflow_node_bindings": {
    "description": "工作流自定义节点条目",
    "hint": "为某个工作流新增一条节点覆盖规则。通过“工作流 ID + 节点 ID + 字段路径”精确定位 workflow_content 中的字段，再用内容类型和输入内容覆盖它",
    "type": "template_list",
    "templates": {
      "binding": {
        "name": "自定义节点条目",
        "display_item": "workflow_id",
        "items": {
          "workflow_id": {
            "description": "所属工作流 ID",
            "hint": "必须与上方某个工作流条目的“工作流 ID”完全一致",
            "type": "string",
            "default": "comfyui_workflow"
          },
          "node_id": {
            "description": "节点 ID",
            "hint": "对应 workflow_content 中该节点的 Key",
            "type": "string",
            "default": ""
          },
          "field_path": {
            "description": "字段路径",
            "hint": "点路径，例如 inputs.text 或 inputs.texts.0",
            "type": "string",
            "default": "inputs.text"
          },
          "binding_type": {
            "description": "内容类型",
            "type": "string",
            "default": "prompt_positive",
            "options": [
              "prompt_positive",
              "prompt_negative",
              "image_input",
              "seed",
              "custom_text",
              "custom_number"
            ],
            "labels": [
              "正向提示词",
              "反向提示词",
              "图片输入",
              "随机种子",
              "自定义文本",
              "自定义数值"
            ]
          },
          "custom_value": {
            "description": "输入内容",
            "hint": "正向提示词会自动使用 /生图 的提示词；反向提示词/任意文本请直接填写文本；随机种子留空则每次随机；任意数值请填写数字（含小数点则按浮点数处理）",
            "type": "string",
            "default": ""
          }
        }
      }
    }
  },
  "workflow_runtime_default": {
    "description": "ComfyUI 运行环境（全局默认）",
    "hint": "供未在工作流条目中单独覆盖运行环境的条目使用",
    "type": "object",
    "items": {
      "base_url": {
        "description": "ComfyUI 地址",
        "hint": "例如 http://127.0.0.1:8188",
        "type": "string",
        "default": "http://127.0.0.1:8188"
      },
      "api_key": {
        "description": "鉴权 Token",
        "hint": "部分 ComfyUI 部署无需鉴权，可留空",
        "type": "string",
        "default": ""
      },
      "poll_interval_seconds": {
        "description": "轮询间隔（秒）",
        "hint": "查询任务状态的时间间隔",
        "type": "float",
        "default": 1.0
      },
      "timeout_seconds": {
        "description": "任务超时时间（秒）",
        "type": "int",
        "default": 180
      }
    }
  },
  "generation_start_message": {
    "description": "生图开始提示",
    "hint": "控制开始生成前是否发送提示语；开启后支持固定语句随机发送或 LLM 生成",
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用生图开始提示",
        "type": "bool",
        "default": true
      },
      "mode": {
        "description": "提示语模式",
        "type": "string",
        "default": "fixed",
        "options": [
          "fixed",
          "llm"
        ],
        "labels": [
          "固定语句",
          "LLM"
        ],
        "condition": {
          "enabled": true
        }
      },
      "fixed_messages": {
        "description": "固定语句列表",
        "hint": "固定语句模式下随机发送，默认为「开始生成」",
        "type": "list",
        "default": [
          "开始生成"
        ],
        "condition": {
          "enabled": true,
          "mode": "fixed"
        }
      },
      "llm_provider_id": {
        "description": "LLM 提示语提供商",
        "hint": "留空则跟随当前默认提供商",
        "type": "string",
        "default": "",
        "_special": "select_provider",
        "condition": {
          "enabled": true,
          "mode": "llm"
        }
      },
      "llm_persona_source": {
        "description": "LLM 提示语人设来源",
        "type": "string",
        "default": "current",
        "options": [
          "current",
          "custom"
        ],
        "labels": [
          "使用当前人设",
          "自定义人设提示词"
        ],
        "condition": {
          "enabled": true,
          "mode": "llm"
        }
      },
      "llm_custom_persona_prompt": {
        "description": "自定义人设提示词",
        "type": "text",
        "default": "根据现在的情景，以适宜的性格言语，简单表述要开始生成图片了，不分段不加格式不使用emoji，10字以内。",
        "hint": "仅在选择自定义人设提示词时生效",
        "condition": {
          "enabled": true,
          "mode": "llm",
          "llm_persona_source": "custom"
        }
      }
    }
  },
  "send_strategy": {
    "description": "全局发送链路",
    "hint": "注意：当生图成功但发送图片失败时，可尝试更改此项；该配置极少需要调整，默认「直连优先」已能覆盖绝大多数场景",
    "type": "string",
    "default": "direct_first",
    "options": [
      "direct_first",
      "event_send_first",
      "context_send_first",
      "platform_client_first",
      "result_pipeline_only"
    ],
    "labels": [
      "直连优先（默认）",
      "事件发送优先",
      "上下文发送优先",
      "平台客户端优先",
      "仅结果管道"
    ]
  }
}
