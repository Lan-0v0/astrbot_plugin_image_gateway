{
  "enable_nl_trigger": {
    "description": "启用自然语言触发",
    "hint": "开启后 LLM 可通过函数工具触发生图/改图；指令始终拥有最高优先级",
    "type": "bool",
    "default": true,
    "obvious_hint": true
  },
  "global_retry_count": {
    "description": "全局默认重试次数",
    "hint": "单个模型未单独配置（-1）时使用此值",
    "type": "int",
    "default": 2,
    "obvious_hint": true
  },
  "global_max_generation_count": {
    "description": "全局默认单次请求最大生成张数上限",
    "hint": "-1 表示不限制；单模型可单独覆盖，超出后提示「超出生成张数上限」",
    "type": "int",
    "default": 2,
    "obvious_hint": true
  },
  "models": {
    "description": "图像生成模型列表",
    "hint": "按优先级从高到低尝试；仅启用的模型参与生成",
    "type": "template_list",
    "templates": {
      "openai": {
        "name": "OpenAI",
        "hint": "OpenAI Images API 或兼容网关",
        "display_item": "display_name",
        "items": {
          "provider_label": {
            "description": "类型",
            "type": "string",
            "default": "OpenAI"
          },
          "display_name": {
            "description": "显示名称",
            "type": "string",
            "default": "OpenAI 模型"
          },
          "enabled": {
            "description": "启用",
            "type": "bool",
            "default": true
          },
          "priority_preset": {
            "description": "优先级",
            "hint": "推荐优先使用预设。条目很多时，只需给重要模型选“最高/高/普通/低/最低”，无需一个个手填数字；只有非常特殊的排序需求才使用“自定义数值”",
            "type": "string",
            "default": "normal",
            "options": [
              "highest",
              "high",
              "normal",
              "low",
              "lowest",
              "custom"
            ],
            "labels": [
              "最高",
              "高",
              "普通",
              "低",
              "最低",
              "自定义数值"
            ]
          },
          "priority": {
            "description": "自定义优先级数值",
            "hint": "仅在“优先级”选择“自定义数值”时使用；数值越大越优先。预设数值对应关系为：最高=40，高=30，普通=20，低=10，最低=0。你可以参考这些数值填写自定义优先级，例如填 25 表示介于“高”和“普通”之间",
            "type": "int",
            "default": 10,
            "condition": {
              "priority_preset": "custom"
            }
          },
          "url": {
            "description": "API 地址",
            "hint": "例如 https://api.openai.com/v1",
            "type": "string",
            "default": "https://api.openai.com/v1"
          },
          "apikey": {
            "description": "API Key",
            "type": "string",
            "default": ""
          },
          "model_name": {
            "description": "模型名称",
            "hint": "例如 gpt-image-2",
            "type": "string",
            "default": "gpt-image-2"
          },
          "retry_count": {
            "description": "重试次数",
            "hint": "-1 表示使用全局默认",
            "type": "int",
            "default": -1
          },
          "max_generation_count": {
            "description": "单次请求最大生成张数",
            "hint": "-1 表示使用全局默认",
            "type": "int",
            "default": -1
          },
          "quality": {
            "description": "画质",
            "type": "string",
            "default": "high",
            "options": [
              "auto",
              "high",
              "medium",
              "low"
            ]
          },
          "size": {
            "description": "尺寸",
            "type": "string",
            "default": "1024x1024",
            "options": [
              "auto",
              "1024x1024",
              "1536x1024",
              "1024x1536",
              "256x256",
              "512x512"
            ]
          },
          "moderation": {
            "description": "内容审核/安全等级",
            "hint": "none 将尝试多种方式降低过滤强度",
            "type": "string",
            "default": "auto",
            "options": [
              "none",
              "low",
              "high",
              "auto"
            ],
            "labels": [
              "关闭 (none)",
              "低 (low)",
              "中高 (high)",
              "自动 (auto)"
            ]
          },
          "seed": {
            "description": "随机种子",
            "hint": "留空表示随机；部分模型/网关不支持",
            "type": "string",
            "default": ""
          },
          "send_strategy": {
            "description": "发送链路",
            "hint": "跟随全局表示使用最底部的「全局发送链路」配置；也可为该模型单独指定",
            "type": "string",
            "default": "follow_global",
            "options": [
              "follow_global",
              "direct_first",
              "event_send_first",
              "context_send_first",
              "platform_client_first",
              "result_pipeline_only"
            ],
            "labels": [
              "跟随全局",
              "直连优先（默认）",
              "事件发送优先",
              "上下文发送优先",
              "平台客户端优先",
              "仅结果管道"
            ]
          }
        }
      },
      "gemini": {
        "name": "Gemini",
        "hint": "Google Gemini 图像生成或 Imagen 兼容接口",
        "display_item": "display_name",
        "items": {
          "provider_label": {
            "description": "类型",
            "type": "string",
            "default": "Gemini"
          },
          "display_name": {
            "description": "显示名称",
            "type": "string",
            "default": "Gemini 模型"
          },
          "enabled": {
            "description": "启用",
            "type": "bool",
            "default": true
          },
          "priority_preset": {
            "description": "优先级",
            "hint": "推荐优先使用预设。条目很多时，只需给重要模型选“最高/高/普通/低/最低”，无需一个个手填数字；只有非常特殊的排序需求才使用“自定义数值”",
            "type": "string",
            "default": "normal",
            "options": [
              "highest",
              "high",
              "normal",
              "low",
              "lowest",
              "custom"
            ],
            "labels": [
              "最高",
              "高",
              "普通",
              "低",
              "最低",
              "自定义数值"
            ]
          },
          "priority": {
            "description": "自定义优先级数值",
            "hint": "仅在“优先级”选择“自定义数值”时使用；数值越大越优先。预设数值对应关系为：最高=40，高=30，普通=20，低=10，最低=0。你可以参考这些数值填写自定义优先级，例如填 25 表示介于“高”和“普通”之间",
            "type": "int",
            "default": 10,
            "condition": {
              "priority_preset": "custom"
            }
          },
          "url": {
            "description": "API 地址",
            "hint": "例如 https://generativelanguage.googleapis.com/v1beta",
            "type": "string",
            "default": "https://generativelanguage.googleapis.com/v1beta"
          },
          "apikey": {
            "description": "API Key",
            "type": "string",
            "default": ""
          },
          "model_name": {
            "description": "模型名称",
            "hint": "例如 gemini-2.0-flash-preview-image-generation",
            "type": "string",
            "default": "gemini-2.0-flash-preview-image-generation"
          },
          "retry_count": {
            "description": "重试次数",
            "hint": "-1 表示使用全局默认",
            "type": "int",
            "default": -1
          },
          "max_generation_count": {
            "description": "单次请求最大生成张数",
            "hint": "-1 表示使用全局默认",
            "type": "int",
            "default": -1
          },
          "quality": {
            "description": "画质/输出质量",
            "hint": "部分网关支持 quality 参数",
            "type": "string",
            "default": "high",
            "options": [
              "auto",
              "high",
              "medium",
              "low"
            ]
          },
          "size": {
            "description": "尺寸/宽高比",
            "hint": "Gemini 原生接口可能忽略此字段",
            "type": "string",
            "default": "1024x1024",
            "options": [
              "auto",
              "1024x1024",
              "1536x1024",
              "1024x1536",
              "1:1",
              "16:9",
              "9:16"
            ]
          },
          "moderation": {
            "description": "安全过滤等级",
            "hint": "none 将尝试 BLOCK_NONE 等多种方式，失败后回退到最低等级",
            "type": "string",
            "default": "default",
            "options": [
              "none",
              "low",
              "high",
              "default"
            ],
            "labels": [
              "关闭 (none)",
              "低 (low)",
              "中高 (high)",
              "默认 (default)"
            ]
          },
          "seed": {
            "description": "随机种子",
            "hint": "留空表示随机",
            "type": "string",
            "default": ""
          },
          "send_strategy": {
            "description": "发送链路",
            "hint": "跟随全局表示使用最底部的「全局发送链路」配置；也可为该模型单独指定",
            "type": "string",
            "default": "follow_global",
            "options": [
              "follow_global",
              "direct_first",
              "event_send_first",
              "context_send_first",
              "platform_client_first",
              "result_pipeline_only"
            ],
            "labels": [
              "跟随全局",
              "直连优先（默认）",
              "事件发送优先",
              "上下文发送优先",
              "平台客户端优先",
              "仅结果管道"
            ]
          }
        }
      }
    }
  },
  "workflows": {
    "description": "工作流（Workflow）列表",
    "hint": "支持 ComfyUI 工作流；可按“仅文生图 / 文生图 + 改图 / 仅改图”参与统一优先级调度",
    "type": "template_list",
    "templates": {
      "comfyui": {
        "name": "ComfyUI",
        "hint": "需要粘贴 ComfyUI 使用“导出（API 格式）”得到的完整工作流 JSON",
        "display_item": "display_name",
        "items": {
          "workflow_id": {
            "description": "工作流 ID",
            "hint": "用于关联下方“工作流自定义节点条目”。建议使用稳定、唯一的英文或拼音标识，例如 portrait_flux",
            "type": "string",
            "default": "comfyui_workflow"
          },
          "display_name": {
            "description": "显示名称",
            "type": "string",
            "default": "ComfyUI 工作流"
          },
          "enabled": {
            "description": "启用",
            "type": "bool",
            "default": true
          },
          "priority_preset": {
            "description": "优先级",
            "hint": "推荐优先使用预设。条目很多时，只需给重要工作流选“最高/高/普通/低/最低”，无需一个个手填数字；只有非常特殊的排序需求才使用“自定义数值”",
            "type": "string",
            "default": "normal",
            "options": [
              "highest",
              "high",
              "normal",
              "low",
              "lowest",
              "custom"
            ],
            "labels": [
              "最高",
              "高",
              "普通",
              "低",
              "最低",
              "自定义数值"
            ]
          },
          "priority": {
            "description": "自定义优先级数值",
            "hint": "仅在“优先级”选择“自定义数值”时使用；数值越大越优先。预设数值对应关系为：最高=40，高=30，普通=20，低=10，最低=0。你可以参考这些数值填写自定义优先级，例如填 25 表示介于“高”和“普通”之间",
            "type": "int",
            "default": 10,
            "condition": {
              "priority_preset": "custom"
            }
          },
          "retry_count": {
            "description": "重试次数",
            "hint": "-1 表示使用全局默认",
            "type": "int",
            "default": -1
          },
          "max_generation_count": {
            "description": "单次请求最大生成张数",
            "hint": "-1 表示使用全局默认",
            "type": "int",
            "default": -1
          },
          "workflow_type": {
            "description": "类型",
            "hint": "当前仅支持 ComfyUI",
            "type": "string",
            "default": "comfyui",
            "options": [
              "comfyui"
            ],
            "labels": [
              "ComfyUI"
            ]
          },
          "supported_modes": {
            "description": "支持模式",
            "hint": "默认仅文生图；如果该 workflow 按单工作流双入口设计，可选择“文生图 + 改图”；如果它只用于改图，也可以选择“仅改图”",
            "type": "string",
            "default": "text_to_image",
            "options": [
              "text_to_image",
              "both",
              "image_to_image"
            ],
            "labels": [
              "仅文生图",
              "文生图 + 改图",
              "仅改图"
            ]
          },
          "runtime_base_url_override": {
            "description": "ComfyUI 地址覆盖",
            "hint": "留空则使用下方「ComfyUI 运行环境（全局默认）」配置",
            "type": "string",
            "default": ""
          },
          "runtime_api_key_override": {
            "description": "ComfyUI 鉴权 Token 覆盖",
            "hint": "留空则使用全局配置；部分 ComfyUI 部署无需鉴权",
            "type": "string",
            "default": ""
          },
          "workflow_content": {
            "description": "工作流内容（API 格式 JSON）",
            "hint": "必须是从 ComfyUI 点击“导出（API 格式）”得到的完整 JSON，不要使用普通导出格式",
            "type": "text",
            "default": ""
          },
          "send_strategy": {
            "description": "发送链路",
            "hint": "跟随全局表示使用最底部的「全局发送链路」配置；也可为该工作流单独指定",
            "type": "string",
            "default": "follow_global",
            "options": [
              "follow_global",
              "direct_first",
              "event_send_first",
              "context_send_first",
              "platform_client_first",
              "result_pipeline_only"
            ],
            "labels": [
              "跟随全局",
              "直连优先（默认）",
              "事件发送优先",
              "上下文发送优先",
              "平台客户端优先",
              "仅结果管道"
            ]
          }
        }
      }
    }
  },
  "workflow_node_bindings": {
    "description": "工作流自定义节点条目",
    "hint": "它是用来告诉插件：工作流里的哪个节点、哪个字段，应该被什么内容自动替换。你可以把它理解成“工作流参数替换规则列表”",
    "type": "template_list",
    "templates": {
      "binding": {
        "name": "自定义节点条目",
        "display_item": "display_name",
        "items": {
          "display_name": {
            "description": "显示名称",
            "hint": "给这条规则起一个你自己容易识别的名字，例如“正向提示词节点”“反向提示词节点”“CFG 参数节点”",
            "type": "string",
            "default": "节点覆盖规则"
          },
          "workflow_id": {
            "description": "所属工作流 ID",
            "hint": "必须与上方某个工作流条目的“工作流 ID”完全一致",
            "type": "string",
            "default": "comfyui_workflow"
          },
          "node_id": {
            "description": "节点 ID",
            "hint": "就是工作流 JSON 里最外层那串节点编号。例如最外层如果有一个编号 6 的节点，那这里就填 6。你只需要照着导出的 API JSON 里最外层的编号填写即可",
            "type": "string",
            "default": ""
          },
          "field_path": {
            "description": "字段路径",
            "hint": "用点号一步一步定位到你想修改的那一项。最常见的是 inputs.text，表示“这个节点里的 inputs 下面的 text”。如果某一项是列表里的第 1 个元素，就像 inputs.texts.0 这样写，最后的 0 表示第一个位置",
            "type": "string",
            "default": "inputs.text"
          },
          "binding_type": {
            "description": "内容类型",
            "hint": "正向提示词应通过 /生图 /改图 指令输入；图片输入为 /改图 指令专用，这两种类型都不需要在配置面板里额外填写输入框",
            "type": "string",
            "default": "prompt_positive",
            "options": [
              "prompt_positive",
              "prompt_negative",
              "image_input",
              "seed",
              "custom_text",
              "custom_number",
              "mode_switch_text",
              "mode_switch_number",
              "mode_switch_json"
            ],
            "labels": [
              "正向提示词",
              "反向提示词",
              "图片输入",
              "随机种子",
              "自定义文本",
              "自定义数值",
              "模式切换文本",
              "模式切换数值",
              "模式切换 JSON"
            ]
          },
          "prompt_negative_value": {
            "description": "输入内容",
            "hint": "这里填写你想固定写入工作流的反向提示词文本",
            "type": "string",
            "default": "",
            "condition": {
              "binding_type": "prompt_negative"
            }
          },
          "custom_text_value": {
            "description": "输入内容",
            "hint": "这里填写任意你想覆盖进去的文本内容",
            "type": "string",
            "default": "",
            "condition": {
              "binding_type": "custom_text"
            }
          },
          "seed_value": {
            "description": "输入内容",
            "hint": "这里填写固定随机种子；留空则每次自动随机生成一个整数",
            "type": "string",
            "default": "",
            "condition": {
              "binding_type": "seed"
            }
          },
          "custom_number_value": {
            "description": "输入内容",
            "hint": "这里填写数字，例如 7、20、0.35。含小数点会按浮点数处理，否则按整数处理",
            "type": "string",
            "default": "",
            "condition": {
              "binding_type": "custom_number"
            }
          },
          "text_to_image_value": {
            "description": "文生图值",
            "hint": "模式切换绑定在 /生图 请求下使用的值。若为 JSON 类型，请填写合法 JSON，例如 [23, 0]",
            "type": "string",
            "default": "",
            "condition": {
              "binding_type@in": [
                "mode_switch_text",
                "mode_switch_number",
                "mode_switch_json"
              ]
            }
          },
          "image_to_image_value": {
            "description": "改图值",
            "hint": "模式切换绑定在 /改图 请求下使用的值。单工作流双入口常用来切换图生图分支、latent 引用或 denoise",
            "type": "string",
            "default": "",
            "condition": {
              "binding_type@in": [
                "mode_switch_text",
                "mode_switch_number",
                "mode_switch_json"
              ]
            }
          }
        }
      }
    }
  },
  "workflow_runtime_default": {
    "description": "ComfyUI 运行环境（全局默认）",
    "hint": "供未在工作流条目中单独覆盖运行环境的条目使用",
    "type": "object",
    "items": {
      "base_url": {
        "description": "ComfyUI 地址",
        "hint": "例如 http://127.0.0.1:8188",
        "type": "string",
        "default": "http://127.0.0.1:8188"
      },
      "api_key": {
        "description": "鉴权 Token",
        "hint": "部分 ComfyUI 部署无需鉴权，可留空",
        "type": "string",
        "default": ""
      },
      "poll_interval_seconds": {
        "description": "轮询间隔（秒）",
        "hint": "查询任务状态的时间间隔",
        "type": "float",
        "default": 1.0
      },
      "timeout_seconds": {
        "description": "任务超时时间（秒）",
        "type": "int",
        "default": 300
      }
    }
  },
  "generation_start_message": {
    "description": "生图开始提示",
    "hint": "控制开始生成前是否发送提示语；开启后支持固定语句随机发送或 LLM 生成",
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用生图开始提示",
        "type": "bool",
        "default": true
      },
      "mode": {
        "description": "提示语模式",
        "type": "string",
        "default": "fixed",
        "options": [
          "fixed",
          "llm"
        ],
        "labels": [
          "固定语句",
          "LLM"
        ],
        "condition": {
          "enabled": true
        }
      },
      "fixed_messages": {
        "description": "固定语句列表",
        "hint": "固定语句模式下随机发送，默认为「开始生成0v0~」",
        "type": "list",
        "default": [
          "开始生成0v0~"
        ],
        "condition": {
          "enabled": true,
          "mode": "fixed"
        }
      },
      "llm_provider_id": {
        "description": "LLM 提示语提供商",
        "hint": "留空则跟随当前默认提供商",
        "type": "string",
        "default": "",
        "_special": "select_provider",
        "condition": {
          "enabled": true,
          "mode": "llm"
