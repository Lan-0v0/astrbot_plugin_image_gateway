{
  "enable_nl_trigger": {
    "description": "启用自然语言触发",
    "hint": "开启后 LLM 可通过函数工具触发生图/改图；指令始终拥有最高优先级",
    "type": "bool",
    "default": true,
    "obvious_hint": true
  },
  "global_retry_count": {
    "description": "全局默认重试次数",
    "hint": "单个模型未单独配置（-1）时使用此值",
    "type": "int",
    "default": 2,
    "obvious_hint": true
  },
  "global_max_generation_count": {
    "description": "全局默认单次请求最大生成张数上限",
    "hint": "-1 表示不限制；单模型可单独覆盖，超出后提示「超出生成张数上限」",
    "type": "int",
    "default": 2,
    "obvious_hint": true
  },
  "models": {
    "description": "图像生成模型列表",
    "hint": "按优先级从高到低尝试；仅启用的模型参与生成",
    "type": "template_list",
    "templates": {
      "openai": {
        "name": "OpenAI",
        "hint": "OpenAI Images API 或兼容网关",
        "display_item": "display_name",
        "items": {
          "provider_label": {
            "description": "类型",
            "type": "string",
            "default": "OpenAI",
            "invisible": true
          },
          "display_name": {
            "description": "显示名称",
            "type": "string",
            "default": "OpenAI 模型"
          },
          "enabled": {
            "description": "启用",
            "type": "bool",
            "default": true
          },
          "priority_preset": {
            "description": "优先级",
            "hint": "推荐优先使用预设。条目很多时，只需给重要模型选“最高/高/普通/低/最低”，无需一个个手填数字；只有非常特殊的排序需求才使用“自定义数值”",
            "type": "string",
            "default": "normal",
            "options": [
              "highest",
              "high",
              "normal",
              "low",
              "lowest",
              "custom"
            ],
            "labels": [
              "最高",
              "高",
              "普通",
              "低",
              "最低",
              "自定义数值"
            ]
          },
          "priority": {
            "description": "自定义优先级数值",
            "hint": "仅在“优先级”选择“自定义数值”时使用；数值越大越优先。预设数值对应关系为：最高=40，高=30，普通=20，低=10，最低=0。你可以参考这些数值填写自定义优先级，例如填 25 表示介于“高”和“普通”之间",
            "type": "int",
            "default": 10,
            "condition": {
              "priority_preset": "custom"
            }
          },
          "url": {
            "description": "API 地址",
            "hint": "例如 https://api.openai.com/v1",
            "type": "string",
            "default": "https://api.openai.com/v1"
          },
          "apikey": {
            "description": "API Key",
            "type": "string",
            "default": ""
          },
          "model_name": {
            "description": "模型名称",
            "hint": "例如 gpt-image-2",
            "type": "string",
            "default": "gpt-image-2"
          },
          "retry_count": {
            "description": "重试次数",
            "hint": "-1 表示使用全局默认",
            "type": "int",
            "default": -1
          },
          "max_generation_count": {
            "description": "单次请求最大生成张数",
            "hint": "-1 表示使用全局默认",
            "type": "int",
            "default": -1
          },
          "supported_modes": {
            "description": "支持模式",
            "hint": "默认文生图 + 改图；如果该模型仅支持文生图或仅支持改图，可切换对应选项",
            "type": "string",
            "default": "both",
            "options": [
              "text_to_image",
              "both",
              "image_to_image"
            ],
            "labels": [
              "仅文生图",
              "文生图 + 改图",
              "仅改图"
            ]
          },
          "quality": {
            "description": "画质",
            "type": "string",
            "default": "high",
            "options": [
              "auto",
              "high",
              "medium",
              "low"
            ]
          },
          "size": {
            "description": "尺寸",
            "type": "string",
            "default": "auto",
            "options": [
              "auto",
              "1024x1024",
              "1536x1024",
              "1024x1536",
              "256x256",
              "512x512"
            ]
          },
          "moderation": {
            "description": "内容审核/安全等级",
            "hint": "none 将尝试多种方式降低过滤强度",
            "type": "string",
            "default": "auto",
            "options": [
              "none",
              "low",
              "high",
              "auto"
            ],
            "labels": [
              "关闭 (none)",
              "低 (low)",
              "中高 (high)",
              "自动 (auto)"
            ]
          },
          "seed": {
            "description": "随机种子",
            "hint": "留空表示随机；部分模型/网关不支持",
            "type": "string",
            "default": ""
          },
          "fake_forward_mode": {
            "description": "消息伪造转发",
            "hint": "跟随全局表示使用下方「全局消息伪造转发」配置；开启后会在生成完成时合并转发开始提示与图片",
            "type": "string",
            "default": "follow_global",
            "options": [
              "follow_global",
              "off",
              "bot_self",
              "requester",
              "custom_qq"
            ],
            "labels": [
              "跟随全局",
              "关闭",
              "Bot自身",
              "生图要求者",
              "自定义QQ号"
            ]
          },
          "fake_forward_custom_qq": {
            "description": "自定义QQ号",
            "hint": "仅在消息伪造转发选择“自定义QQ号”时生效",
            "type": "string",
            "default": "",
            "condition": {
              "fake_forward_mode": "custom_qq"
            }
          },
          "send_strategy": {
            "description": "发送链路",
            "hint": "跟随全局表示使用最底部的「全局发送链路」配置；也可为该模型单独指定",
            "type": "string",
            "default": "follow_global",
            "options": [
              "follow_global",
              "direct_first",
              "event_send_first",
              "context_send_first",
              "platform_client_first",
              "result_pipeline_only"
            ],
            "labels": [
              "跟随全局",
              "直连优先（默认）",
              "事件发送优先",
              "上下文发送优先",
              "平台客户端优先",
              "仅结果管道"
            ]
          }
        }
      },
